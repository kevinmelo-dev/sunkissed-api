APP_NAME="Sunkissed Swimwear"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost:8080
APP_PORT=8080
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR

# Docker host user mapping (WSL/Linux). Override if your UID/GID differ.
UID=1000
GID=1000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=sunkissed
DB_USERNAME=sunkissed
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

# Redis (cache + queues)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# Sanctum / SPA
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000
FRONTEND_URL=http://localhost:3000

# S3-compatible storage (AWS S3 OR Cloudflare R2 — both use the s3 driver)
# For R2: set AWS_ENDPOINT to your R2 endpoint and AWS_DEFAULT_REGION=auto
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

# Audit log archive disk (reuses s3 config above unless overridden)
AUDIT_ARCHIVE_DISK=s3
AUDIT_ARCHIVE_PATH=audit-logs

# Mercado Pago (Checkout Pro)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# OTP channel: email (MVP) | sms | whatsapp
OTP_CHANNEL=email
OTP_CODE_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# Stock reservation TTL (minutes) before release
STOCK_RESERVATION_TTL_MINUTES=30

# Shipping
MELHOR_ENVIO_TOKEN=
MELHOR_ENVIO_SANDBOX=true
FREE_SHIPPING_THRESHOLD_CENTS=20000

# Mail (MVP OTP channel)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="nao-responda@sunkissedswimwear.com.br"
MAIL_FROM_NAME="${APP_NAME}"
