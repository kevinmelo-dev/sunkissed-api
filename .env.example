APP_NAME="Sunkissed Swimwear"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost:8080
APP_PORT=8080
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR

# Docker host user mapping (WSL/Linux). Override if your UID/GID differ.
UID=1000
GID=1000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=sunkissed
DB_USERNAME=sunkissed
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

# Redis (cache + queues)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# Sanctum / SPA
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000
FRONTEND_URL=http://localhost:3000

# Cloudflare R2 storage — one token scoped to both buckets
# images disk: public bucket for product images
# audit disk:  private bucket for audit log archives
R2_ENDPOINT=
R2_KEY=
R2_SECRET=
R2_IMAGES_BUCKET=
R2_IMAGES_URL=
R2_AUDIT_BUCKET=

AUDIT_ARCHIVE_DISK=audit
AUDIT_ARCHIVE_PATH=audit-logs

# Mercado Pago (Checkout Pro)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# OTP channel: email (MVP) | sms | whatsapp
OTP_CHANNEL=email
OTP_CODE_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# Stock reservation TTL (minutes) before release
STOCK_RESERVATION_TTL_MINUTES=30

# Shipping
MELHOR_ENVIO_TOKEN=
MELHOR_ENVIO_SANDBOX=true
FREE_SHIPPING_THRESHOLD_CENTS=20000

# Mail (MVP OTP channel)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="nao-responda@sunkissedswimwear.com.br"
MAIL_FROM_NAME="${APP_NAME}"
